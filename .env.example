# Uygulamanin calisacagi ortam.
APP_ENV=local

# FastAPI uygulamasinin kullanacagi temel bilgi.
APP_NAME=BIST100 AI Platform
API_V1_PREFIX=/api/v1

# Signal modulu riskli oldugu icin varsayilan olarak kapali.
SIGNAL_ENABLED=false
PAPER_TRADE_ENABLED=false

# PostgreSQL baglanti ayarlari.
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/bist100_ai
DATABASE_ECHO=false

# Aktif market data provider secimi: mock, yahoo_delayed veya matriks.
MARKET_DATA_PROVIDER=yahoo_delayed
YAHOO_TIMEOUT_SECONDS=8.0
FMP_API_KEY=
FMP_BASE_URL=https://financialmodelingprep.com/stable
FMP_TIMEOUT_SECONDS=8.0
EODHD_API_TOKEN=
EODHD_BASE_URL=https://eodhd.com/api
EODHD_TIMEOUT_SECONDS=8.0
MARKET_SNAPSHOT_MAX_AGE_MINUTES=2
OHLCV_CACHE_MAX_AGE_MINUTES_1H=45
OHLCV_CACHE_MAX_AGE_MINUTES_4H=90
OHLCV_CACHE_MAX_AGE_MINUTES_1G=360
OHLCV_CACHE_MAX_AGE_MINUTES_1W=1440
KAP_SECTORS_URL=https://www.kap.org.tr/en/Sektorler
KAP_TIMEOUT_SECONDS=10.0

# Garanti / Matriks canli snapshot ayarlari.
# Gecerli token verirseniz dogrudan kullanilir; token yoksa username/password ile otomatik login denenir.
MATRIKS_BASE_URL=https://api.matriksdata.com
MATRIKS_MARKET_DATA_TOKEN=
MATRIKS_INTEGRATION_URL=https://etrader.garantibbvayatirim.com.tr/0172_v3_trader/Integration.aspx
MATRIKS_SSO_LOGIN_SERVICE=https://ssomatriks.garantibbvayatirim.com.tr/9984_sso_etrader/Integration.aspx
MATRIKS_SSO_HASHKEY_SERVICE=https://ssomatriks.garantibbvayatirim.com.tr/9984_sso_etrader/SSOCheckState.aspx
MATRIKS_SSO_DATE_SERVICE=https://ssomatriks.garantibbvayatirim.com.tr/9984_sso_etrader/UTCDate.aspx
MATRIKS_SSO_TID=prodTr
MATRIKS_SNAPSHOT_PATH=/dumrul/v1/snapshot-market-real
MATRIKS_BAR_PATH=/dumrul/v1/tick/bar.gz
MATRIKS_DEPTH_PATH=
MATRIKS_SOURCE_ID=40
MATRIKS_EXCHANGE_ID=4
MATRIKS_CLIENT_IP=127.0.0.1
MATRIKS_PLATFORM=D
MATRIKS_LANGUAGE=tr
MATRIKS_VERSION=20250804.20250915.20240520.20241017
MATRIKS_USERNAME=
MATRIKS_PASSWORD=
MATRIKS_CUSTOMER_NO=
MATRIKS_ACCOUNT_ID=
MATRIKS_SESSION_KEY=
MATRIKS_LOGIN_ACTION=
MATRIKS_LOGIN_OTP=
MATRIKS_SYMBOL_SUFFIX=
MATRIKS_BAR_PERIOD_1H=5min
MATRIKS_BAR_PERIOD_4H=5min
MATRIKS_BAR_PERIOD_1G=1day
MATRIKS_BAR_PERIOD_1W=
MATRIKS_TIMEOUT_SECONDS=5.0
MATRIKS_VERIFY_SSL=true

# Legacy alan geriye donuk uyumluluk icin tutuluyor.
MATRIKS_TERMINAL_ID=

# Market data retention politikasi.
MARKET_SNAPSHOT_RETENTION_DAYS=14
OHLCV_RETENTION_DAYS_1H=45
OHLCV_RETENTION_DAYS_4H=180
OHLCV_RETENTION_DAYS_1G=1825
OHLCV_RETENTION_DAYS_1W=3650

SCHEDULER_ENABLED=true
SCHEDULER_CLEANUP_INTERVAL_MINUTES=360
SCHEDULER_PREFETCH_ENABLED=true
SCHEDULER_PREFETCH_INTERVAL_MINUTES=60
SCHEDULER_PREFETCH_BARS=120
SCHEDULER_PREFETCH_TIMEFRAMES=1H,4H,1G
SCHEDULER_PREFETCH_TICKERS=
SCHEDULER_PREFETCH_INITIAL_DELAY_MINUTES=0
SCHEDULER_PAPER_LOG_ENABLED=true
SCHEDULER_PAPER_LOG_INTERVAL_MINUTES=1440
SCHEDULER_PAPER_LOG_LIMIT=10
SCHEDULER_PAPER_LOG_STANCE=bullish
SCHEDULER_PAPER_LOG_STANCES=bullish,neutral
SCHEDULER_PAPER_LOG_INITIAL_DELAY_MINUTES=5
SCHEDULER_PAPER_LOG_WAIT_FOR_PREFETCH=true

NEWS_IMPACT_PROVIDER=marketaux
MARKETAUX_API_TOKEN=
MARKETAUX_BASE_URL=https://api.marketaux.com/v1
MARKETAUX_LANGUAGE=en
MARKETAUX_COUNTRIES=tr
MARKETAUX_TIMEOUT_SECONDS=8.0
